# JWT 密钥（必需，请使用强随机字符串）
JWT_SECRET=your_jwt_secret_key_here

# CORS 允许的域名（逗号分隔，用于生产环境）
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-domain.com

# 旧版 Gemini API Key（可选，已支持 OpenAI 兼容接口）
GEMINI_API_KEY=your_gemini_api_key_here

# 新版 API 设置（推荐通过前端设置界面配置）
# 支持 OpenAI 风格接口，可在应用中点击设置图标配置:
# - API Base URL (支持 OpenAI, Anthropic, Google, DeepSeek, 通义千问等)
# - API Key
# - 模型选择

# 和风天气 API 配置
# 获取 API Key: https://console.qweather.com
QWEATHER_API_KEY=your_qweather_api_key_here
# 获取 API Host: https://console.qweather.com/settings
QWEATHER_API_HOST=devapi.qweather.com

# MySQL 数据库配置（可选，不配置则使用 SQLite）
# 本地开发：MYSQL_HOST=localhost
# Docker 部署（MySQL 也在容器中）：MYSQL_HOST=<MySQL容器名称>
# MYSQL_PORT=3306
# MYSQL_USER=aiwardrobe
# MYSQL_PASSWORD=your_password
# MYSQL_DATABASE=aiwardrobe

# 初始化管理员账户（仅首次部署生效）
# INIT_ADMIN_USER=syh
# INIT_ADMIN_PASS=qwer1234

# MinIO 对象存储配置
MINIO_ENDPOINT=aiwardrobe.syhzyt.cc:9000
MINIO_ACCESS_KEY=sunyahui
MINIO_SECRET_KEY=qwer1234
MINIO_BUCKET=aiwardrobe
MINIO_SECURE=false
